# Batch Creative Studio — environment template
# Copy to .env.local and fill in the secrets (".env.local" is gitignored).
#   cp .env.example .env.local
# In production these live as Vercel project env vars (vercel env pull .env.local to sync).

# ─────────────────────────────────────────────────────────────
# Image-generation providers (failover chain)
# ─────────────────────────────────────────────────────────────

# PRIMARY — Google Gemini 2.5 Flash Image ("Nano Banana"). Free tier ~500 img/day, no card.
# Get it: https://aistudio.google.com/apikey  (Create API key)
GEMINI_API_KEY=

# SECONDARY — Cloudflare Workers AI (FLUX.2 klein / FLUX.1 schnell / SDXL). Free 10k neurons/day.
# Account ID: Cloudflare dashboard → Workers & Pages (right sidebar "Account ID"),
#   or the hex in the dashboard URL dash.cloudflare.com/<ACCOUNT_ID>.
CLOUDFLARE_ACCOUNT_ID=
# API token: dashboard → My Profile → API Tokens → Create Token → "Workers AI" template
#   (perms: Account · Workers AI · Read+Edit). https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
# Model id. Default = FLUX.2 [klein] (gen+EDIT: accepts reference images, so the
# secondary keeps image-reference conditioning). Set a text-only model
# (@cf/black-forest-labs/flux-1-schnell or @cf/stabilityai/stable-diffusion-xl-base-1.0)
# to make this provider prompt-only (degradation badge in the UI).
CLOUDFLARE_MODEL=@cf/black-forest-labs/flux-2-klein-9b
CLOUDFLARE_RPM=30                 # per-provider rate limit (token bucket)
CLOUDFLARE_DAILY_QUOTA=200        # soft daily cap for the quota pre-switch

# TERTIARY (optional, full-product) — Replicate. Off by default.
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
REPLICATE_ENABLED=false           # when true, appended to the chain as tertiary
# Model ref: "owner/name" (latest) or "owner/name:version" (pinned).
REPLICATE_MODEL=black-forest-labs/flux-dev
# Which model input key receives the reference (style) image: "image" (img2img),
# or "redux_image" / "image_prompt" for a Redux / IP-Adapter model.
REPLICATE_IMAGE_INPUT_KEY=image
REPLICATE_RPM=10
REPLICATE_DAILY_QUOTA=100

# FREE (primary, product-PRESERVING) — HuggingFace FLUX.1-Kontext-dev. A TRUE
# image-editing (img2img) model: it preserves the PRODUCT image and restyles it
# per the prompt — the only free option that keeps the product intact. It also does
# TRUE reference STYLE-TRANSFER: when reference image(s) are supplied, the adapter
# stitches the product (LEFT) beside the reference(s) (RIGHT) into one image and
# Kontext re-lights/re-stages the product to the reference's mood, lighting, and
# color palette while keeping the product itself accurate. Gated on a fine-grained
# token with the "Inference Providers" permission (server-side only):
#   https://huggingface.co/settings/tokens/new?ownUserPermissions=inference.serverless.write&tokenType=fineGrained
# Omitted from the chain when HF_TOKEN is empty (gated, like Cloudflare/Pollinations).
HF_TOKEN=
# Model id (default = the product-preserving Kontext edit model).
HUGGINGFACE_MODEL=black-forest-labs/FLUX.1-Kontext-dev
# Inference Provider that runs the model. Default = fal-ai (live-verified). Others:
# replicate, together, nebius, … (must be enabled for the model on your HF account).
HUGGINGFACE_PROVIDER=fal-ai
HUGGINGFACE_RPM=6                 # conservative: free monthly Inference-Providers credit
HUGGINGFACE_DAILY_QUOTA=100       # soft daily cap for the quota pre-switch
# Backstop timeout (ms) for the cold-start hang: the first call to a cold provider
# can hang forever; the adapter races it against this + the per-attempt signal so a
# hang becomes a retryable timeout (the warm retry then succeeds).
HUGGINGFACE_TIMEOUT_MS=120000
# Vision model used ONCE per job to read the reference image's MOOD into text (so a
# single-image edit model can re-style the product in that mood). The extractor
# tries this first, then built-in fallbacks (Qwen2.5-VL, Llama-3.2-Vision).
HUGGINGFACE_VISION_MODEL=google/gemma-3-27b-it

# FREE — Pollinations. Image-input (img2img) generation gated on a free account
# token. Get a token (free): https://enter.pollinations.ai
# Omitted from the chain when POLLINATIONS_TOKEN is empty (gated, like Cloudflare).
POLLINATIONS_TOKEN=
# Model. Default = gptimage: the image-INPUT model that works with the FREE token.
# nanobanana / kontext / seedream are PREMIUM-only on enter.pollinations.ai —
# they 500 ("only available on enter.pollinations.ai") even with the free token.
POLLINATIONS_MODEL=gptimage
POLLINATIONS_RPM=6                # conservative: anonymous tier ~1 req/15s; a token raises it
POLLINATIONS_DAILY_QUOTA=100      # soft daily cap for the quota pre-switch

# ─────────────────────────────────────────────────────────────
# Storage — Vercel Blob (uploads + results)
# ─────────────────────────────────────────────────────────────
# Provisioned when you add a Blob store to the Vercel project
#   (Vercel dashboard → Storage → Blob → Connect), then `vercel env pull .env.local`.
BLOB_READ_WRITE_TOKEN=

# ─────────────────────────────────────────────────────────────
# Shared state store — Upstash Redis (multi-instance prod)
# ─────────────────────────────────────────────────────────────
# Enables a SHARED Job/Item/Attempt state store + a cross-instance run-once claim,
# so on Vercel's multi-instance serverless POST /api/jobs (one instance) and the
# SSE stream / snapshot (another instance) see the SAME job. WITHOUT it they hit
# different in-memory stores and the client gets "batch no longer available".
#   PRESENT → Redis-backed shared store (production). Each job has a 1-hour TTL.
#   ABSENT  → in-memory store (local dev + tests). No external dependency.
# Provision via Upstash (https://console.upstash.com → Redis → Create) or the Vercel
# Marketplace (Storage → Upstash for Redis → Connect), then `vercel env pull .env.local`.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# A Vercel KV / Upstash integration may instead expose the same client as the pair
# below — Redis.fromEnv() auto-reads either pair, so set ONE pair, not both:
#   KV_REST_API_URL= / KV_REST_API_TOKEN=

# ─────────────────────────────────────────────────────────────
# Orchestration tunables (no redeploy needed to change)
# ─────────────────────────────────────────────────────────────
POOL_SIZE=5                       # bounded worker pool (concurrency), 4–6
ATTEMPT_CAP=3                     # attempts per provider (1 initial + 2 retries)
ATTEMPT_TIMEOUT_MS=60000          # per provider call; a timeout is retryable
BACKOFF_BASE_MS=500               # retry backoff base: min(cap, base*2^attempt + jitter)
BACKOFF_MAX_MS=8000               # retry backoff cap (server Retry-After honored beyond cap)
PROVIDER_CHAIN=huggingface,cloudflare  # failover order (FREE chain, default)
                                  # huggingface = FLUX.1-Kontext-dev img2img (PRIMARY,
                                  #   product-preserving); pollinations + cloudflare are free
                                  #   fallbacks for when the HF monthly credit is exhausted.
                                  # append ,replicate when REPLICATE_ENABLED=true.
MAX_ITEMS=20                      # max product images per batch (N)
GEMINI_RPM=10                     # per-provider rate limit (token bucket)
GEMINI_DAILY_QUOTA=500            # used for quota-based pre-switch to Cloudflare
QUOTA_SOFT_FRACTION=0.9           # daily-quota soft threshold for the pre-switch hook (Task 9)

# ─────────────────────────────────────────────────────────────
# API route guards (POST /api/jobs)
# ─────────────────────────────────────────────────────────────
JOBS_RATE_LIMIT_PER_MIN=30        # per-IP rate limit on POST /api/jobs (429 on exceed)
JOB_IDEMPOTENCY_WINDOW_MS=60000   # Idempotency-Key window: same key → same jobId
# SSRF allowlist for user-supplied image URLs (CSV of host suffixes). Default:
# the Vercel Blob public host. Override only if you serve uploads from elsewhere.
# BLOB_ALLOWED_HOST_SUFFIXES=.public.blob.vercel-storage.com

# ─────────────────────────────────────────────────────────────
# Full-product scope (NOT used in MVP — left here for reference)
# ─────────────────────────────────────────────────────────────
# DATABASE_URL=                   # Postgres/Neon — persistence (deferred)
# KV_URL=                         # KV/Upstash — worker coordination (deferred)

# ─────────────────────────────────────────────────────────────
# Observability (optional — configured by /observability)
# ─────────────────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=
